# apps/web .env.example
# Copy this file to .env and fill in real values.
# 复制此文件为 .env 并填入实际值。

# Base URL for API requests / API 请求基础地址
VITE_BASE_URL=/api

# Local Vite proxy target / 本地 Vite API 代理目标
VITE_DEV_API_TARGET=http://127.0.0.1:8000

# Application title displayed in the browser tab
VITE_APP_TITLE=Sun World

# LangChain / LangSmith configuration (optional, for AI features)
# VITE_LANGCHAIN_TRACING_V2=true
# VITE_LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# VITE_LANGCHAIN_API_KEY=your_langsmith_api_key
# VITE_LANGCHAIN_PROJECT=blog
