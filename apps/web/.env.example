# apps/web .env.example
# Copy this file to .env and fill in real values.
# 复制此文件为 .env 并填入实际值。

# Base URL for API requests / API 请求基础地址
VITE_BASE_URL=/api

# Local Vite proxy target / 本地 Vite API 代理目标
VITE_DEV_API_TARGET=http://127.0.0.1:8000

# Application title displayed in the browser tab
VITE_APP_TITLE=Sun World

# Do not put LangSmith/OpenAI/private API keys in Vite env variables.
# VITE_* values are bundled into browser JavaScript.
