{
  "name": "@sun-world/ui",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/ui.cjs.js",
  "module": "dist/ui.es.js",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "build": "vite build --mode lib",
    "test": "vitest run"
  },
  "sideEffects": [
    "dist/*.css",
    "src/styles/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/ui.es.js",
      "require": "./dist/ui.cjs.js",
      "default": "./dist/ui.es.js"
    },
    "./button": {
      "types": "./dist/types/button.d.ts",
      "import": "./dist/button.es.js",
      "default": "./dist/button.es.js"
    },
    "./input": {
      "types": "./dist/types/input.d.ts",
      "import": "./dist/input.es.js",
      "default": "./dist/input.es.js"
    },
    "./date-picker": {
      "types": "./dist/types/date-picker.d.ts",
      "import": "./dist/date-picker.es.js",
      "default": "./dist/date-picker.es.js"
    },
    "./list": {
      "types": "./dist/types/list.d.ts",
      "import": "./dist/list.es.js",
      "default": "./dist/list.es.js"
    },
    "./pagination": {
      "types": "./dist/types/pagination.d.ts",
      "import": "./dist/pagination.es.js",
      "default": "./dist/pagination.es.js"
    },
    "./tag": {
      "types": "./dist/types/tag.d.ts",
      "import": "./dist/tag.es.js",
      "default": "./dist/tag.es.js"
    },
    "./loading-skeleton": {
      "types": "./dist/types/loading-skeleton.d.ts",
      "import": "./dist/loading-skeleton.es.js",
      "default": "./dist/loading-skeleton.es.js"
    },
    "./theme-provider": {
      "types": "./dist/types/theme-provider.d.ts",
      "import": "./dist/theme-provider.es.js",
      "default": "./dist/theme-provider.es.js"
    },
    "./dist/*": "./dist/*"
  },
  "dependencies": {
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^24.1.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.0.6"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
