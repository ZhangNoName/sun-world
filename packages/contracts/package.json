{
  "name": "@sun-world/contracts",
  "version": "0.0.1",
  "private": true,
  "description": "Shared API contracts between frontend and backend",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "generate:openapi": "node ../../scripts/generate-openapi.mjs",
    "generate:types": "openapi-typescript openapi.json -o src/generated-api-types.ts",
    "generate": "pnpm generate:openapi && pnpm generate:types",
    "build": "pnpm generate"
  },
  "files": [
    "openapi.json",
    "src"
  ],
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "vitest": "^2.1.9"
  }
}
