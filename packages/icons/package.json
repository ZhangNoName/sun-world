{
  "name": "@sun-world/icons",
  "version": "0.0.1",
  "main": "dist/icons.umd.js",
  "module": "dist/icons.es.js",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "build": "vite build --mode lib",
    "dev": "vite",
    "test": "vitest run",
    "build:preview": "vite build --mode preview"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/icons.es.js",
      "require": "./dist/icons.umd.js",
      "default": "./dist/icons.es.js"
    },
    "./core": {
      "types": "./dist/types/core.d.ts",
      "import": "./dist/core.es.js",
      "default": "./dist/core.es.js"
    },
    "./vue": {
      "types": "./dist/types/vue/index.d.ts",
      "import": "./dist/vue.es.js",
      "default": "./dist/vue.es.js"
    },
    "./dist/*": "./dist/*"
  },
  "dependencies": {
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^24.1.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.0.6"
  },
  "files": [
    "dist",
    "NOTICE.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
