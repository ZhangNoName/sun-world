{
  "name": "sun-world",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "run-p dev:icons dev:editor dev:web",
    "dev:web": "pnpm -F @sun-world/blog dev",
    "dev:blog": "pnpm dev:web",
    "dev:api": "node scripts/start-api.mjs",
    "dev:api:install": "node scripts/start-api.mjs --install-only",
    "dev:local": "node dev.mjs",
    "dev:icons": "pnpm -F @sun-world/icons dev",
    "watch:editor": "pnpm -F @sun-world/editor run watch",
    "build": "pnpm build:editor && pnpm build:icons && pnpm build:ui && pnpm build:web",
    "build:web": "node scripts/run-workspace-script.mjs @sun-world/blog build --max-old-space-size=4096",
    "build:blog": "pnpm build:web",
    "build:editor": "node scripts/run-workspace-script.mjs @sun-world/editor build --max-old-space-size=4096",
    "build:icons": "node scripts/run-workspace-script.mjs @sun-world/icons build --max-old-space-size=2048",
    "build:ui": "pnpm -F @sun-world/ui run build",
    "build:api": "docker compose --profile api build api",
    "format": "node scripts/format-changed.mjs --write",
    "format:check": "node scripts/format-changed.mjs --check",
    "test:ui": "pnpm -F @sun-world/ui run test",
    "test:contracts": "pnpm -F @sun-world/contracts run test",
    "sun-ai": "node tools/sun-ai-cli/src/cli.mjs",
    "check:sun-ai:contracts": "node scripts/check-sun-ai-contract-sync.mjs",
    "check:sun-ai:cli": "node scripts/check-sun-ai-cli.mjs",
    "check:contracts:generate": "node scripts/check-contracts-generate-script.mjs",
    "check:contracts:usage": "node scripts/check-contract-route-usage.mjs",
    "check:web:legacy-api": "node scripts/check-legacy-api-entrypoints.mjs",
    "check:ai-interface": "node scripts/check-ai-interface.mjs",
    "build:web:manifest": "node scripts/generate-web-build-manifest.mjs",
    "check:web:manifest": "node scripts/check-web-build-manifest.mjs",
    "build:web:summary": "node scripts/generate-web-build-summary.mjs",
    "check:web:summary": "node scripts/check-web-build-summary.mjs",
    "check:web:ui-boundary": "node scripts/check-ui-package-boundary.mjs",
    "check:root-script": "node scripts/check-root-check-script.mjs",
    "check:dev-launcher": "node scripts/check-dev-launcher.mjs",
    "check:github-actions:ci": "node scripts/check-github-actions-ci.mjs",
    "check:github-actions:deploy": "node scripts/check-github-actions-deploy.mjs",
    "check:api:deploy-schema": "node scripts/check-api-deploy-schema.mjs",
    "check:platform": "node scripts/check-platform-goal-audit.mjs",
    "check:web:chunks": "node scripts/check-web-chunks.mjs",
    "compose:config": "docker compose config",
    "check:dockerfile": "node scripts/check-docker-build-context.mjs",
    "check:api-dockerfile": "node scripts/check-api-dockerfile-cache.mjs",
    "check:compose": "node scripts/check-docker-build-context.mjs && node scripts/check-api-dockerfile-cache.mjs && node scripts/verify-compose.mjs",
    "check:web": "node scripts/check-web.mjs",
    "check:web:budgets": "node scripts/check-web-budgets.mjs",
    "check:api": "node scripts/run-api-check.mjs",
    "check": "node scripts/check-all.mjs"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.17.11",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/compiler-sfc": "^3.5.13",
    "axios": "^1.7.9",
    "esbuild": "^0.23.1",
    "eslint": "^8.57.1",
    "minimist": "^1.2.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "unplugin-dts": "1.0.0-beta.0",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.4.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vue": "^3.5.13",
    "vue-tsc": "^1.8.27"
  },
  "dependencies": {
    "artplayer": "^5.3.0",
    "artplayer-plugin-danmuku": "^5.2.0",
    "artplayer-plugin-document-pip": "^1.0.2",
    "artplayer-plugin-hls-control": "^1.0.1",
    "hls.js": "^1.6.15",
    "jszip": "^3.10.1",
    "moment": "^2.30.1",
    "pinia": "^3.0.3",
    "uuid": "^13.0.0",
    "vditor": "^3.10.8"
  }
}
